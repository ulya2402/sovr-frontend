{
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "https://backend-sovr.botgampang123.workers.dev/sitemap.xml"
    },
    {
      "source": "/(feed/.*|perspectives/.*|vault.*)",
      "has": [
        {
          "type": "header",
          "key": "user-agent",
          "value": "(?i).*(bot|whatsapp|telegram|twitter|facebook|linkedin|discord|slack|skype).*"
        }
      ],
      "destination": "/api/preview?path=$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}